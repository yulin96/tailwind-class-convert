{
  "name": "tailwind-class-convert",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.1",
  "publisher": "yulin96",
  "author": "yulin96",
  "repository": {
    "type": "git",
    "url": "https://github.com/yulin96/tailwind-class-convert.git"
  },
  "homepage": "https://github.com/yulin96/tailwind-class-convert#readme",
  "bugs": {
    "url": "https://github.com/yulin96/tailwind-class-convert/issues"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "tailwind",
    "tailwind css",
    "tailwindcss",
    "class",
    "class name",
    "class converter",
    "class transform",
    "shorthand class",
    "utility class",
    "css utility",
    "legacy css",
    "migration",
    "convert on save",
    "formatter",
    "html",
    "vue",
    "react",
    "svelte",
    "astro"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "tailwind-class-convert.convert",
        "title": "%command.convert.title%"
      },
      {
        "command": "tailwind-class-convert.toggle",
        "title": "%command.toggle.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "tailwindClassConvert.enableMode": {
          "type": "string",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "enumDescriptions": [
            "%configuration.enableMode.auto%",
            "%configuration.enableMode.on%",
            "%configuration.enableMode.off%"
          ],
          "default": "auto",
          "scope": "resource",
          "description": "%configuration.enableMode.description%"
        },
        "tailwindClassConvert.convertOnSave": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "%configuration.convertOnSave.description%"
        },
        "tailwindClassConvert.showStatusBar": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "%configuration.showStatusBar.description%"
        },
        "tailwindClassConvert.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "default": [
            "html",
            "vue",
            "javascriptreact",
            "typescriptreact",
            "svelte",
            "astro"
          ],
          "scope": "resource",
          "description": "%configuration.languages.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
